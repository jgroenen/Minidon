# Minidon Configuration
# Copy this file to .env and fill in your values

# Instance name - shown in headers
INSTANCE_NAME=Minidon

# Tagline - shown below the instance name
TAGLINE=Federated microblogging server

# Posts per page for pagination
POSTS_PER_PAGE=20

# Data directory - where actors and posts are stored
DATA_DIR=data

# Template directory - where XSLT templates are stored
TEMPLATE_DIR=templates
